# Copy to .env (gitignored) and fill in real values.
# Quarkus reads these as config at dev/test startup.

QUARKUS_DATASOURCE_JDBC_URL=jdbc:postgresql://localhost:5432/hx_qute
QUARKUS_DATASOURCE_USERNAME=scaffold_dba
QUARKUS_DATASOURCE_PASSWORD=changeme

# One-time database setup (as postgres superuser):
#   CREATE ROLE scaffold_dba LOGIN PASSWORD '<password>';
#   CREATE DATABASE hx_qute OWNER scaffold_dba;
# Flyway creates and seeds the schema on first application start.
